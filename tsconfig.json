{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/db/*": ["src/db/*"],
      "@/lib/*": ["src/lib/*"]
    }
  },
  "include": ["api/**/*.ts", "src/**/*.ts"]
}
